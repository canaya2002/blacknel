{
  "name": "blacknel",
  "version": "0.0.0",
  "private": true,
  "description": "Blacknel — all-in-one SaaS for social media, reviews, messaging, AI replies, reputation and reporting.",
  "type": "module",
  "engines": {
    "node": "22.x",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint . --max-warnings=0 --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "pnpm lint && pnpm typecheck && pnpm test",
    "db:migrate": "tsx --tsconfig=tsconfig.scripts.json scripts/migrate.ts",
    "db:seed": "tsx --tsconfig=tsconfig.scripts.json scripts/seed.ts",
    "db:reset": "tsx --tsconfig=tsconfig.scripts.json scripts/reset-db.ts",
    "db:rls": "tsx --tsconfig=tsconfig.scripts.json scripts/rls-switch.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-collapsible": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-radio-group": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@sentry/nextjs": "^10.53.1",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.0",
    "@tanstack/react-query": "^5.62.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.36.4",
    "jose": "^5.9.0",
    "lucide-react": "^0.469.0",
    "next": "^16.0.0",
    "next-themes": "^0.4.0",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "posthog-node": "^5.34.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-virtuoso": "^4.18.7",
    "recharts": "^3.8.1",
    "tailwind-merge": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.14",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "drizzle-kit": "^0.28.1",
    "eslint": "^9.16.0",
    "eslint-config-next": "^16.0.0",
    "jsdom": "^25.0.1",
    "pino-pretty": "^11.3.0",
    "postcss": "^8.4.0",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
