# =============================================================================
# Blacknel — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in real values. Never commit `.env*`.
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser.
# =============================================================================

# --- App -------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Supabase (added in Commit 2) ------------------------------------
# Project: blacknel-dev (Supabase Cloud)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Database (Drizzle direct connection, added in Commit 2) ---------
# Use the "Connection string" from Supabase project settings → Database.
# Direct connection (5432) for migrations; pooler (6543) for runtime.
DATABASE_URL=
DATABASE_URL_POOLED=

# --- Feature flags ---------------------------------------------------
BLACKNEL_USE_MOCKS=true
BLACKNEL_MOCK_ERRORS=false
