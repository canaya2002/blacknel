# =============================================================================
# Blacknel — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in real values. Never commit `.env*`.
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser.
# =============================================================================

# --- App -------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Supabase (added in Commit 2) ------------------------------------
# Project: blacknel-dev (Supabase Cloud)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Database (Drizzle direct connection, added in Commit 2) ---------
# Use the "Connection string" from Supabase project settings → Database.
# Direct connection (5432) for migrations; pooler (6543) for runtime.
DATABASE_URL=
DATABASE_URL_POOLED=

# --- Auth (cookie-based session in Phases 1-10) ----------------------
# JWT HS256 signing secret. Generate with:
#   node -e "console.log(crypto.randomBytes(48).toString('base64url'))"
# Must be ≥ 32 chars in production. Dev falls back to a stable placeholder
# baked into lib/auth/cookie.ts so sessions persist across restarts even
# without this variable set.
BLACKNEL_COOKIE_SECRET=

# --- Feature flags ---------------------------------------------------
BLACKNEL_USE_MOCKS=true
BLACKNEL_MOCK_ERRORS=false
# Set true to advance synthetic connector events on /integrations visits
# (expired tokens, sync runs). Useful for QA of error / banner states.
BLACKNEL_MOCK_EVENTS=false

# Publish-job cron (Commit 20a). Default `true` so `pnpm dev` runs
# the in-process tick every 60s. Vitest setup sets it to `false`
# automatically — the test runtime always uses the per-test
# pglite, never the real cron. Set to `false` here if you're
# running pnpm dev but explicitly DON'T want the job ticking
# (rare). Phase 11 swaps to Inngest Cloud and this flag becomes
# unused.
BLACKNEL_PUBLISH_JOB_ENABLED=true
