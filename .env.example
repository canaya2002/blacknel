# =============================================================================
# Blacknel — environment template. Copy to `.env.local` and fill in.
#
#   cp .env.example .env.local
#
# NEVER commit `.env.local`. Every value below is a PLACEHOLDER — no real
# secrets live in this file.
#
# ⚠️  PRODUCTION SAFETY
#     `.env.local` is what every `pnpm db:*` command, `pnpm db:rls`, a local
#     `next build`, and `pnpm dev` read. If BLACKNEL_USE_MOCKS=false AND
#     DATABASE_URL points at a real Supabase project, those commands touch
#     that real database. For everyday local dev keep BLACKNEL_USE_MOCKS=true
#     (pglite, no external DB, no creds). Only set DATABASE_URL +
#     BLACKNEL_USE_MOCKS=false when you deliberately intend to target a real
#     DB — and be certain which one (prod vs staging).
# =============================================================================

# --- Core ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (Supabase Postgres / Drizzle) -----------------------------------
# Session pooler URL (port 5432, host aws-<n>-<region>.pooler.supabase.com).
# Leave UNSET for local pglite dev (BLACKNEL_USE_MOCKS=true).
DATABASE_URL=
# Optional transaction-pooler URL. Currently NOT consumed by code (the client
# uses DATABASE_URL); documented for operators / future pooled path.
DATABASE_URL_POOLED=

# --- Supabase Auth (used when BLACKNEL_USE_REAL_AUTH=true) ---------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Session cookie (JOSE path, when BLACKNEL_USE_REAL_AUTH=false) -------------
# Must be >= 32 chars in production.
BLACKNEL_COOKIE_SECRET=

# --- Meta (Facebook / Instagram / Threads / WhatsApp) App Review --------------
# App secret — validates signed_request (data-deletion) and webhook HMAC.
META_APP_SECRET=
# Verify-token echoed during the webhook subscription handshake. Must match
# the value set in the Meta App Dashboard exactly.
META_WEBHOOK_VERIFY_TOKEN=

# --- Runtime mode / mocks -----------------------------------------------------
# true (default) → pglite + deterministic mock connectors, no external creds.
BLACKNEL_USE_MOCKS=true
BLACKNEL_MOCK_ERRORS=false
BLACKNEL_MOCK_EVENTS=false

# --- In-process cron flags (only fire when NODE_ENV=development) ---------------
BLACKNEL_PUBLISH_JOB_ENABLED=true
BLACKNEL_ADS_SYNC_ENABLED=true
BLACKNEL_ADS_ALERTS_ENABLED=true
BLACKNEL_NPS_JOB_ENABLED=true
BLACKNEL_LISTENING_JOB_ENABLED=true
BLACKNEL_SCHEDULED_REPORTS_JOB_ENABLED=true
BLACKNEL_AUDIT_ANOMALY_JOB_ENABLED=true
BLACKNEL_AUDIT_RETENTION_JOB_ENABLED=true

# --- Seed flags (seedDatabase) ------------------------------------------------
BLACKNEL_SEED_CONNECTED=true
BLACKNEL_SEED_PUBLISHING=true
BLACKNEL_SEED_WHATSAPP=true
BLACKNEL_SEED_NPS=true
BLACKNEL_SEED_LISTENING=true
BLACKNEL_SEED_COMPETITORS_REPORTS=true
BLACKNEL_SEED_ENTERPRISE_NETWORKS=true
BLACKNEL_SEED_CUSTOM_REPORTS=true
# Only honored in production when explicitly set; UNSET after a one-off run.
BLACKNEL_SEED_DEMO_ORG=false

# --- Phase 11 cutover flags ---------------------------------------------------
BLACKNEL_USE_REAL_AUTH=false
BLACKNEL_USE_REAL_SENTRY=false
BLACKNEL_USE_REAL_POSTHOG=false
# Informational-only visibility flag; the real RLS switch is the rls_dynamic
# row in app_settings, flipped with `pnpm db:rls on/off`.
BLACKNEL_USE_REAL_RLS_DYNAMIC=false

# --- Admin / master org (gates /admin/*) --------------------------------------
BLACKNEL_MASTER_ORG_ID=11111111-1111-4111-8111-111111111111

# --- Observability ------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
POSTHOG_KEY=
POSTHOG_HOST=https://us.posthog.com

# --- Operations ---------------------------------------------------------------
# false | read-only | true   (procedure: doc/runbooks/kill-switch.md)
BLACKNEL_KILL_SWITCH=false

# --- Logging ------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=pretty

# =============================================================================
# Manual live tests — DANGER: targets the real DATABASE_URL
# -----------------------------------------------------------------------------
# Leave UNSET. Setting BLACKNEL_LIVE_TEST=true together with a real
# DATABASE_URL makes a plain `pnpm test` run the *.live.test.ts suites, which
# INSERT/DELETE sentinel rows (9e9e9e9e-*) against that database.
# BLACKNEL_LIVE_TEST=
# =============================================================================

# -----------------------------------------------------------------------------
# Read via raw process.env (NOT through lib/env.ts — see audit category G):
#   BLACKNEL_PUBLIC_URL        public review-request links (lib/reviews/send-request.ts)
#   BLACKNEL_MOCK_FAST_PUBLISH test-only fast publish-delay knob
# ANTHROPIC_API_KEY is added in the Phase-11 AI cutover (lib/ai/adapter-real.ts).
# -----------------------------------------------------------------------------
